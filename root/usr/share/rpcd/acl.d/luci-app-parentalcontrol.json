{
	"luci-app-parentalcontrol": {
		"description": "Grant access to Parental Control",
		"read": {
			"ubus": {
				"parentalcontrol": ["get_status", "list_devices"]
			},
			"uci": ["parentalcontrol"]
		},
		"write": {
			"ubus": {
