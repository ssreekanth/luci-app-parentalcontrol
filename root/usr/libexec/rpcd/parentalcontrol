#!/bin/sh

# rpcd plugin for luci-app-parentalcontrol

. /lib/functions.sh
. /usr/share/libubox/jshn.sh

CONFIG_NAME="parentalcontrol"
SCRIPT="/usr/libexec/parentalcontrol.sh"

handle_get_status() {
	local global_enabled now

	config_load "$CONFIG_NAME"
	config_get global_enabled global enabled '0'
	now=$(date +%s)

	json_init
	json_add_boolean "global_enabled" "$global_enabled"
	json_add_array "rules"

	_emit_rule() {
		local section="$1"
		local name mac rule_enabled override_until
		config_get name "$section" name ""
		config_get mac "$section" mac ""
		config_get rule_enabled "$section" enabled '1'
		config_get override_until "$section" override_until '0'

		local status="inactive"
		local override_remaining=0

		if [ "$global_enabled" = "1" ] && [ "$rule_enabled" = "1" ]; then
			if [ -n "$override_until" ] && [ "$override_until" != "0" ] && [ "$now" -lt "$override_until" ]; then
				status="override"
				override_remaining=$(( override_until - now ))
			else
				status="active"
			fi
		fi

		local schedules=""
		_collect_schedule() {
			if [ -z "$schedules" ]; then
				schedules="$1"
			else
				schedules="$schedules|$1"
			fi
		}
		config_list_foreach "$section" schedule _collect_schedule

		json_add_object ""
		json_add_string "section" "$section"
		json_add_string "name" "$name"
		json_add_string "mac" "$mac"
		json_add_boolean "enabled" "$rule_enabled"
		json_add_string "status" "$status"
		json_add_int "override_remaining" "$override_remaining"
		json_add_string "schedules" "$schedules"
		json_close_object
	}

	config_foreach _emit_rule rule

	json_close_array
	json_dump
}

handle_list_devices() {
	local seen_macs=""

	json_init
	json_add_array "devices"

	if [ -f /tmp/dhcp.leases ]; then
		while read -r _ts mac ip hostname _rest; do
			[ -z "$mac" ] && continue
			[ "$hostname" = "*" ] && hostname=""
			json_add_object ""
			json_add_string "mac" "$mac"
			json_add_string "ip" "$ip"
			json_add_string "hostname" "${hostname:-unknown}"
			json_close_object
		done < /tmp/dhcp.leases
		seen_macs=$(awk '{print tolower($2)}' /tmp/dhcp.leases)
	fi

	if [ -f /proc/net/arp ]; then
		while read -r ip _ _ mac _ _iface; do
			[ "$ip" = "IP" ] && continue
			[ "$mac" = "00:00:00:00:00:00" ] && continue
			local mac_lower
			mac_lower=$(echo "$mac" | tr 'A-Z' 'a-z')
			if ! echo "$seen_macs" | grep -q "$mac_lower"; then
				json_add_object ""
				json_add_string "mac" "$mac"
				json_add_string "ip" "$ip"
				json_add_string "hostname" ""
				json_close_object
			fi
		done < /proc/net/arp
	fi

	json_close_array
	json_dump
}

handle_toggle_global() {
	local input enabled
	read -r input
	json_load "$input"
	json_get_var enabled enabled

	uci set "$CONFIG_NAME.global.enabled=$enabled"
	uci commit "$CONFIG_NAME"
	$SCRIPT apply

	json_init
	json_add_boolean "success" 1
	json_dump
}

handle_toggle_rule() {
	local input section enabled
	read -r input
	json_load "$input"
	json_get_var section section
	json_get_var enabled enabled

	uci set "$CONFIG_NAME.$section.enabled=$enabled"
	uci commit "$CONFIG_NAME"
	$SCRIPT apply

	json_init
	json_add_boolean "success" 1
	json_dump
}

handle_set_override() {
	local input section minutes until_ts
	read -r input
	json_load "$input"
	json_get_var section section
	json_get_var minutes minutes

	until_ts=$(( $(date +%s) + minutes * 60 ))

	uci set "$CONFIG_NAME.$section.override_until=$until_ts"
	uci commit "$CONFIG_NAME"
	$SCRIPT apply

	json_init
	json_add_boolean "success" 1
	json_add_int "override_until" "$until_ts"
	json_dump
}

handle_cancel_override() {
	local input section
	read -r input
	json_load "$input"
	json_get_var section section

	uci set "$CONFIG_NAME.$section.override_until=0"
	uci commit "$CONFIG_NAME"
	$SCRIPT apply

	json_init
	json_add_boolean "success" 1
	json_dump
}

handle_add_rule() {
	local input name mac schedules enabled section sched
	read -r input
	json_load "$input"
	json_get_var name name
	json_get_var mac mac
	json_get_var schedules schedules
	json_get_var enabled enabled

	section=$(uci add "$CONFIG_NAME" rule)
	uci set "$CONFIG_NAME.$section.name=$name"
	uci set "$CONFIG_NAME.$section.mac=$mac"
	uci set "$CONFIG_NAME.$section.enabled=${enabled:-1}"
	uci set "$CONFIG_NAME.$section.override_until=0"

	echo "$schedules" | tr '|' '\n' | while read -r sched; do
		[ -z "$sched" ] && continue
		uci add_list "$CONFIG_NAME.$section.schedule=$sched"
	done

	uci commit "$CONFIG_NAME"
	$SCRIPT apply

	json_init
	json_add_boolean "success" 1
	json_add_string "section" "$section"
	json_dump
}

handle_update_rule() {
	local input section name schedules enabled sched
	read -r input
	json_load "$input"
	json_get_var section section
	json_get_var name name
	json_get_var schedules schedules
	json_get_var enabled enabled

	[ -n "$name" ] && uci set "$CONFIG_NAME.$section.name=$name"
	[ -n "$enabled" ] && uci set "$CONFIG_NAME.$section.enabled=$enabled"

	if [ -n "$schedules" ]; then
		uci delete "$CONFIG_NAME.$section.schedule" 2>/dev/null
		echo "$schedules" | tr '|' '\n' | while read -r sched; do
			[ -z "$sched" ] && continue
			uci add_list "$CONFIG_NAME.$section.schedule=$sched"
		done
	fi

	uci commit "$CONFIG_NAME"
	$SCRIPT apply

	json_init
	json_add_boolean "success" 1
	json_dump
}

handle_move_rule() {
	local input move_section direction
	read -r input
	json_load "$input"
	json_get_var move_section section
	json_get_var direction direction

	config_load "$CONFIG_NAME"

	local target_idx=-1 rule_count=0
	_find_rule() {
		if [ "$1" = "$move_section" ]; then
			target_idx=$rule_count
		fi
		rule_count=$((rule_count + 1))
	}
	config_foreach _find_rule rule

	local new_abs=-1
	if [ "$direction" = "up" ] && [ "$target_idx" -gt 0 ]; then
		new_abs=$target_idx
	elif [ "$direction" = "down" ] && [ "$target_idx" -ge 0 ] && [ "$target_idx" -lt $((rule_count - 1)) ]; then
		new_abs=$((target_idx + 2))
	fi

	if [ "$new_abs" -ge 0 ]; then
		uci reorder "$CONFIG_NAME.$move_section=$new_abs"
		uci commit "$CONFIG_NAME"
		$SCRIPT apply

		json_init
		json_add_boolean "success" 1
		json_dump
	else
		json_init
		json_add_boolean "success" 0
		json_dump
	fi
}

handle_delete_rule() {
	local input section
	read -r input
	json_load "$input"
	json_get_var section section

	uci delete "$CONFIG_NAME.$section"
	uci commit "$CONFIG_NAME"
	$SCRIPT apply

	json_init
	json_add_boolean "success" 1
	json_dump
}

case "$1" in
	list)
		echo '{'
		echo '"get_status":{},'
		echo '"list_devices":{},'
		echo '"toggle_global":{"enabled":true},'
		echo '"toggle_rule":{"section":"str","enabled":true},'
		echo '"set_override":{"section":"str","minutes":30},'
		echo '"add_rule":{"name":"str","mac":"str","schedules":"str","enabled":true},'
		echo '"cancel_override":{"section":"str"},'
		echo '"move_rule":{"section":"str","direction":"str"},'
		echo '"delete_rule":{"section":"str"},'
		echo '"update_rule":{"section":"str","name":"str","schedules":"str","enabled":true}'
		echo '}'
		;;
	call)
		case "$2" in
			get_status) handle_get_status ;;
			list_devices) handle_list_devices ;;
			toggle_global) handle_toggle_global ;;
			toggle_rule) handle_toggle_rule ;;
			set_override) handle_set_override ;;
			cancel_override) handle_cancel_override ;;
			add_rule) handle_add_rule ;;
			update_rule) handle_update_rule ;;
			move_rule) handle_move_rule ;;
			delete_rule) handle_delete_rule ;;
		esac
		;;
esac
